PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT — generate strong random values, do NOT reuse these placeholders
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRY=1h
MFA_TOKEN_EXPIRY=5m

# Internal service-to-service key (used by Cognigy for audit logging)
INTERNAL_SERVICE_KEY=change-me-to-a-long-random-secret

# CORS (comma-separated origin allowlist)
CORS_ORIGINS=http://localhost:3000
